{
  "name": "markdown-viewer",
  "version": "1.0.0",
  "description": "A lightweight desktop Markdown viewer with GitHub-style rendering",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --config electron-builder.config.cjs",
    "package:win": "electron-vite build && electron-builder --win --config electron-builder.config.cjs"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "dompurify": "^3.3.1"
  },
  "devDependencies": {
    "@shikijs/markdown-it": "^3.3.0",
    "@vitejs/plugin-react": "^5.1.3",
    "@vscode/markdown-it-katex": "^1.1.2",
    "electron": "^40.2.1",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "katex": "^0.16.28",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shiki": "^3.3.0",
    "vite": "^7.3.1"
  }
}
